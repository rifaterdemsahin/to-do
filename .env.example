# .env.example - Local environment variables template
# NOTE: Real secrets are never committed to git. Load them at runtime via Azure Key Vault.

# --- AZURE KEY VAULT CONFIGURATION ---
AZURE_KEYVAULT_NAME="dg-pilot-kv"
AZURE_TENANT_ID="your-azure-tenant-id"
AZURE_CLIENT_ID="your-service-principal-client-id"
AZURE_CLIENT_SECRET="your-service-principal-client-secret"

# --- DATABASE & SERVICES (PULLED FROM KEY VAULT AT RUNTIME) ---
# Direct Database connection URL (Supabase connection pooler, port 6543)
DATABASE_URL="postgresql://postgres:password@host:6543/postgres"

# AI/LLM Provider API Keys
AI_PROVIDER_API_KEY="your-api-key-here"

# --- SUPABASE (DATABASE & BACKEND FEATURES) ---
# Frontend-safe (anon key, protected by Row Level Security):
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY="your-supabase-anon-key"
# Backend only — NEVER expose to the browser:
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# --- AXIOM (SERVER-SIDE LOGS) ---
AXIOM_TOKEN="xaat-your-axiom-api-token"
AXIOM_DATASET="delivery-pilot-dev"
# Optional: AXIOM_ORG_ID for org-scoped tokens

# --- FLY.IO (CONTAINER-BASED DEPLOYMENTS) ---
# Used by CI/CD to deploy; store in Key Vault, expose to GitHub Actions:
FLY_API_TOKEN="your-fly-api-token"
FLY_APP_NAME="your-fly-app-name"

# --- LOCAL AI SERVICES CONFIGURATION (OLLAMA + QDRANT) ---
OLLAMA_HOST="http://localhost:11434"
QDRANT_HOST="http://localhost:6333"
EMBEDDING_MODEL="nomic-embed-text"
